NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/sports_facility_saas

# ── Super Admin Credentials (read by seed.js) ─────────────────
# Set these BEFORE running the setup script on Oracle Cloud.
# The seed script will create the superadmin with these credentials.
# If not set, defaults are: admin@venuepro.com / Admin@123
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=Admin@venuepro.com
SUPER_ADMIN_PASSWORD=Admin@123

# ── JWT Secrets ───────────────────────────────────────────────
# Generate strong secrets locally: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=https://your-frontend-domain.vercel.app

# ── Request Limits ────────────────────────────────────────────
REQUEST_SIZE_LIMIT=10mb

# ── Optional Email (SMTP) ────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=VenuePro <noreply@yourdomain.com>
