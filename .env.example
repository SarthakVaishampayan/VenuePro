# ============================================================
# VENUEPRO SAAS — Environment Variables
# ============================================================

# === Server ===
PORT=5000
NODE_ENV=development

# === MongoDB ===
MONGODB_URI=mongodb://localhost:27017/sports_facility_saas

# === JWT ===
JWT_ACCESS_SECRET=change-this-to-a-random-secret-string
JWT_REFRESH_SECRET=change-this-to-another-random-secret-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === Rate Limiting ===
REQUEST_SIZE_LIMIT=10mb

# === Logging ===
LOG_LEVEL=info

# === Encryption (for future use) ===
ENCRYPTION_KEY=

# === Super Admin Credentials (for seeding) ===
SUPER_ADMIN_EMAIL=admin@venuepro.com
SUPER_ADMIN_PASSWORD=Admin@123

